# Copy this file to .env and fill in values before running deploy.sh
# .env is gitignored — never commit real secrets

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=orgHub

# ── JWT (min 32 characters) ───────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_SECRET_KEY

# ── URLs (must match your domain) ────────────────────────────────────────────
VITE_API_URL=https://uorghub.unitymicrofund.com/api/v1
ALLOWED_ORIGINS=https://uorghub.unitymicrofund.com
