## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/

# VS Code settings
.vscode/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# Others
*.dbmdl
*.cache
*.pdb
*.mdb

# Ignore packages if you're using NuGet
packages/
